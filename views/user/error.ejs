<%- include('../partials/header') %>
<%- include('../partials/navbar', { user: user }) %>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="text-center p-5" style="background: white; border-radius: 15px; border-left: 4px solid var(--gold);">
                <i class="fas fa-exclamation-triangle" style="font-size: 64px; color: var(--gold);"></i>
                <h3 style="color: var(--navy); margin-top: 20px;"><%= message %></h3>
                <a href="<%= redirectUrl %>" class="btn-gold mt-3">Go Back</a>
