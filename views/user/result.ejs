<%- include('../partials/header') %>
<%- include('../partials/navbar', { user: user }) %>

<style>
    .result-card {
        background: var(--white);
        border-radius: 20px;
        padding: 40px;
        text-align: center;
        max-width: 600px;
        margin: 50px auto;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        border: 1px solid rgba(128,0,32,0.1);
    }
    .score-circle {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--gold), var(--gold-dark));
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 20px auto;
    }
    .score-number {
        font-size: 48px;
        font-weight: bold;
        color: var(--maroon);
    }
    .percentage {
        font-size: 24px;
        color: var(--maroon);
    }
    .email-status {
        margin-top: 20px;
        padding: 10px;
        border-radius: 10px;
        font-size: 14px;
    }
    .email-success {
        background: rgba(40,167,69,0.1);
        color: #28a745;
        border: 1px solid #28a745;
    }
    .email-failed {
        background: rgba(220,53,69,0.1);
        color: #dc3545;
        border: 1px solid #dc3545;
    }
    .btn-gold {
        background: linear-gradient(135deg, var(--gold), var(--gold-dark));
        color: var(--maroon);
        border: none;
        padding: 12px 30px;
        border-radius: 25px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        margin-top: 20px;
    }
</style>

<div class="container">
    <div class="result-card">
        <i class="fas fa-check-circle" style="font-size: 64px; color: #28a745;"></i>
        <h2 style="color: var(--maroon);">Exam Submitted Successfully!</h2>

        <div class="score-circle">
            <div>
                <div class="score-number"><%= score %>/<%= totalMarks %></div>
                <div class="percentage"><%= Math.round(percentage) %>%</div>
            </div>
        </div>

        <div class="email-status <%= emailSent ? 'email-success' : 'email-failed' %>">
            <i class="fas <%= emailSent ? 'fa-check-circle' : 'fa-exclamation-circle' %>"></i>
            <%= emailSent ? '✅ Results have been sent to your email address!' : '⚠️ Email notification could not be sent. Please check your email settings.' %>
        </div>

        <p>Your results have been recorded. You can view detailed analysis in your profile.</p>

        <div style="margin-top: 20px;">
            <a href="/user/dashboard" class="btn-gold">Back to Dashboard</a>
            <a href="/user/profile" class="btn-back ml-2">View Profile & Analytics</a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>