<%- include('partials/header') %>

<div class="auth-wrapper">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <div class="auth-logo">
                    <i class="fas fa-user-plus"></i>
                    <h2>STUDENT<span class="gold-text">REGISTRATION</span></h2>
                </div>
                <h3>Create Your Account</h3>
                <p>Join ExamSystem for online examinations</p>
            </div>

            <div class="auth-body">
                <% if (error) { %>
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-circle"></i> <%= error %>
                    </div>
                <% } %>

                <form action="/register" method="POST">
                    <div class="form-group">
                        <label for="name">
                            <i class="fas fa-user"></i> Full Name
                        </label>
                        <input type="text" class="form-control" id="name" name="name"
                               placeholder="Enter your full name" required>
                    </div>

                    <div class="form-group">
                        <label for="email">
                            <i class="fas fa-envelope"></i> Email Address
                        </label>
                        <input type="email" class="form-control" id="email" name="email"
                               placeholder="Enter your college email" required>
                        <small class="form-text">Use your college email address (e.g., 24r11a62f3@gcet.edu.in)</small>
                    </div>

                    <div class="form-group">
                        <label for="password">
                            <i class="fas fa-lock"></i> Password
                        </label>
                        <input type="password" class="form-control" id="password" name="password"
                               placeholder="Create a password" required>
                        <small class="form-text">Minimum 6 characters</small>
                    </div>

                    <div class="form-group">
                        <label for="confirmPassword">
                            <i class="fas fa-check-circle"></i> Confirm Password
                        </label>
                        <input type="password" class="form-control" id="confirmPassword" name="confirmPassword"
                               placeholder="Confirm your password" required>
                    </div>

                    <button type="submit" class="btn-auth">
                        <i class="fas fa-user-plus"></i> Register as Student
                    </button>
                </form>

                <div class="auth-footer">
                    <p>Already have an account? <a href="/user/login">Login here</a></p>
                    <a href="/" class="back-home">
                        <i class="fas fa-arrow-left"></i> Back to Home
                    </a>
                </div>
            </div>
        </div>

        <div class="auth-decoration">
            <div class="decoration-text">
                <i class="fas fa-info-circle"></i>
                <h4>Why Register?</h4>
                <ul>
                    <li><i class="fas fa-check-circle"></i> Take online exams</li>
                    <li><i class="fas fa-check-circle"></i> Track your performance</li>
                    <li><i class="fas fa-check-circle"></i> Get instant results</li>
                    <li><i class="fas fa-check-circle"></i> Email notifications</li>
                    <li><i class="fas fa-check-circle"></i> Question-wise analysis</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer-simple') %>