<%- include('partials/header') %>
<%- include('partials/navbar') %>

<!-- Hero Section -->
<section id="home" class="hero-section">
    <div class="video-background">
        <video autoplay muted loop>
            <source src="https://assets.mixkit.co/videos/preview/mixkit-programming-and-coding-2299-large.mp4" type="video/mp4">
        </video>
        <div class="video-overlay"></div>
    </div>
    <div class="hero-content">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto text-center">
                    <div class="welcome-badge animate-fade-in">
                        <i class="fas fa-star-of-life"></i> WELCOME TO EXAM SYSTEM
                    </div>
                    <h1 class="hero-title animate-fade-in-delay">
                        <span class="white-text">Next-Generation</span><br>
                        <span class="gold-text">Online Examination</span><br>
                        <span class="white-text">Platform</span>
                    </h1>
                    <div class="hero-divider animate-fade-in-delay">
                        <span class="divider-line"></span>
                        <i class="fas fa-graduation-cap"></i>
                        <span class="divider-line"></span>
                    </div>
                    <p class="hero-subtitle animate-fade-in-delay-2">
                        Secure • Reliable • Smart • Efficient
                    </p>
                    <div class="hero-buttons animate-fade-in-delay-2">
                        <a href="/user/login" class="btn-hero-primary">
                            <i class="fas fa-user-graduate"></i> Student Portal
                        </a>
                        <a href="/admin/login" class="btn-hero-secondary">
                            <i class="fas fa-user-shield"></i> Admin Portal
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section id="features" class="features-section">
    <div class="container">
        <div class="section-header text-center">
            <h2>Why Choose <span class="gold-text">ExamSystem</span>?</h2>
            <p class="section-subtitle">Comprehensive features for modern examination needs</p>
        </div>
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <h4>Timed Exams</h4>
                    <p>Strict time management with auto-submit feature when time expires</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-random"></i>
                    </div>
                    <h4>Randomized Questions</h4>
                    <p>Unique question order for every student to prevent cheating</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <h4>Advanced Analytics</h4>
                    <p>Question-wise performance tracking and detailed analysis</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <h4>Email Notifications</h4>
                    <p>Automatic score reports and exam notifications via email</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h4>Secure Platform</h4>
                    <p>Bank-level security with encrypted data and secure sessions</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-tachometer-alt"></i>
                    </div>
                    <h4>Real-time Monitoring</h4>
                    <p>Live tracking of exam progress and student performance</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="stats-section">
    <div class="container">
        <div class="row">
            <div class="col-md-3 mb-4">
                <div class="stat-card">
                    <div class="stat-number">5000+</div>
                    <div class="stat-label">Students</div>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="stat-card">
                    <div class="stat-number">100+</div>
                    <div class="stat-label">Exams</div>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="stat-card">
                    <div class="stat-number">98%</div>
                    <div class="stat-label">Satisfaction</div>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="stat-card">
                    <div class="stat-number">24/7</div>
                    <div class="stat-label">Support</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works Section -->
<section id="about" class="how-it-works-section">
    <div class="container">
        <div class="section-header text-center">
            <h2>How <span class="gold-text">ExamSystem</span> Works</h2>
            <p class="section-subtitle">Simple 3-step process to conduct online exams</p>
        </div>
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <div class="step-icon">
                        <i class="fas fa-user-plus"></i>
                    </div>
                    <h4>Register / Login</h4>
                    <p>Create your account or login with your credentials</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="step-card">
                    <div class="step-number">2</div>
                    <div class="step-icon">
                        <i class="fas fa-pen-alt"></i>
                    </div>
                    <h4>Take Exam</h4>
                    <p>Attempt exam with timer and randomized questions</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="step-card">
                    <div class="step-number">3</div>
                    <div class="step-icon">
                        <i class="fas fa-chart-bar"></i>
                    </div>
                    <h4>Get Results</h4>
                    <p>Instant results and detailed performance analysis</p>
                </div>
            </div>
        </div>
    </div>
</section>

