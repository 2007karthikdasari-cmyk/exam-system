<%- include('../partials/header') %>
<%- include('../partials/navbar', { user: user }) %>

<style>
    .exams-container {
        max-width: 1200px;
        margin: 0 auto;
    }
    .exam-card {
        background: linear-gradient(135deg, rgba(26,26,26,0.95), rgba(10,10,10,0.95));
        border: 1px solid rgba(212,175,55,0.3);
        border-radius: 15px;
        margin-bottom: 20px;
        transition: all 0.3s ease;
    }
    .exam-card:hover {
        transform: translateY(-3px);
        border-color: var(--gold);
        box-shadow: 0 10px 30px rgba(212,175,55,0.2);
    }
    .exam-header {
        padding: 20px;
        border-bottom: 1px solid rgba(212,175,55,0.2);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .exam-title {
        color: var(--gold);
        font-size: 20px;
        font-weight: 600;
        margin: 0;
    }
    .exam-body {
        padding: 20px;
    }
    .action-buttons {
        display: flex;
        gap: 10px;
    }
    .btn-action {
        padding: 8px 15px;
        border-radius: 8px;
        text-decoration: none;
        font-size: 14px;
        transition: all 0.3s ease;
    }
    .btn-edit {
        background: rgba(212,175,55,0.2);
        border: 1px solid var(--gold);
        color: var(--gold);
    }
    .btn-edit:hover {
        background: var(--gold);
        color: var(--black);
    }
    .btn-questions {
        background: rgba(40,167,69,0.2);
        border: 1px solid #28a745;
        color: #51cf66;
    }
    .btn-questions:hover {
        background: #28a745;
        color: white;
    }
    .btn-delete {
        background: rgba(220,53,69,0.2);
        border: 1px solid #dc3545;
        color: #ff6b6b;
    }
    .btn-delete:hover {
        background: #dc3545;
        color: white;
    }
    .question-count {
        background: rgba(212,175,55,0.2);
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 12px;
        color: var(--gold);
    }
</style>

<div class="container mt-4">
    <div class="exams-container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="gold-text"><i class="fas fa-chalkboard"></i> Manage Exams</h2>
                <p class="text-white">View, edit, or delete your exams</p>
            </div>
            <a href="/admin/create-exam" class="btn-gold">
                <i class="fas fa-plus-circle"></i> Create New Exam
            </a>
        </div>

        <div id="exams-list">
            <!-- Exams will be loaded here -->
        </div>
    </div>
</div>

<script>
    // Load exams from server
    async function loadExams() {
        try {
            const response = await fetch('/admin/api/exams');
            const exams = await response.json();

            const container = document.getElementById('exams-list');
            if (exams.length === 0) {
                container.innerHTML = `
                    <div class="text-center p-5">
                        <i class="fas fa-folder-open fa-4x" style="color: var(--gold); opacity: 0.5;"></i>
                        <p class="mt-3">No exams created yet. Click "Create New Exam" to get started.</p>
                    </div>
                `;
                return;
            }

            container.innerHTML = exams.map(exam => `
                <div class="exam-card">
                    <div class="exam-header">
                        <div>
                            <h3 class="exam-title">${exam.title}</h3>
                            <small class="text-muted">Created: ${new Date(exam.created_at).toLocaleDateString()}</small>
                        </div>
                        <div class="action-buttons">
                            <span class="question-count">
                                <i class="fas fa-question-circle"></i> ${exam.question_count || 0} Questions
                            </span>
                        </div>
                    </div>
                    <div class="exam-body">
                        <p class="text-white">${exam.description || 'No description provided.'}</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="badge-${exam.is_active ? 'active' : 'inactive'}">
                                    ${exam.is_active ? 'Active' : 'Inactive'}
                                </span>
                                <span class="ms-2"><i class="fas fa-clock"></i> ${exam.duration} minutes</span>
                            </div>
                            <div class="action-buttons">
                                <a href="/admin/exam/${exam.id}/edit" class="btn-action btn-edit">
                                    <i class="fas fa-edit"></i> Edit Exam
                                </a>
                                <a href="/admin/exam/${exam.id}/questions" class="btn-action btn-questions">
                                    <i class="fas fa-list"></i> Manage Questions
                                </a>
                                <button onclick="deleteExam(${exam.id})" class="btn-action btn-delete">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        } catch (error) {
            console.error('Error loading exams:', error);
        }
    }

    async function deleteExam(examId) {
        if (confirm('Are you sure you want to delete this exam? All questions will also be deleted.')) {
            try {
                const response = await fetch(`/admin/api/exams/${examId}`, { method: 'DELETE' });
                const data = await response.json();
                if (data.success) {
                    alert('Exam deleted successfully!');
                    loadExams();
                } else {
                    alert('Error deleting exam');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error deleting exam');
            }
        }
    }

    loadExams();
</script>

<%- include('../partials/footer') %>