<%- include('../partials/header') %>
<%- include('../partials/navbar', { user: user }) %>

<style>
    .questions-container {
        max-width: 1200px;
        margin: 0 auto;
    }
    .question-card {
        background: linear-gradient(135deg, rgba(26,26,26,0.95), rgba(10,10,10,0.95));
        border: 1px solid rgba(212,175,55,0.3);
        border-radius: 15px;
        margin-bottom: 25px;
        overflow: hidden;
    }
    .question-header {
        background: linear-gradient(135deg, rgba(0,0,0,0.8), rgba(0,0,0,0.9));
        padding: 15px 20px;
        border-bottom: 1px solid rgba(212,175,55,0.3);
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
    }
    .question-header:hover {
        background: rgba(212,175,55,0.1);
    }
    .question-number {
        color: var(--gold);
        font-weight: 600;
    }
    .question-body {
        padding: 20px;
        display: none;
    }
    .question-body.active {
        display: block;
    }
    .options-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-top: 15px;
    }
    .option-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(212,175,55,0.2);
        border-radius: 10px;
        padding: 15px;
    }
    .option-card label {
        color: var(--gold);
        font-weight: 600;
        margin-bottom: 10px;
        display: block;
    }
    .option-input, .image-input {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(212,175,55,0.3);
        border-radius: 8px;
        padding: 10px 15px;
        color: var(--white);
        width: 100%;
        margin-bottom: 10px;
    }
    .option-input:focus, .image-input:focus {
        outline: none;
        border-color: var(--gold);
    }
    .image-preview {
        max-width: 100%;
        max-height: 150px;
        margin-top: 10px;
        border-radius: 8px;
        display: none;
    }
    .image-preview.active {
        display: block;
    }
    .btn-add-question {
        background: transparent;
        border: 2px dashed var(--gold);
        color: var(--gold);
        padding: 15px;
        border-radius: 15px;
        width: 100%;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-bottom: 25px;
    }
    .btn-add-question:hover {
        background: rgba(212,175,55,0.1);
        border-style: solid;
    }
    .btn-remove-question {
        background: rgba(220,53,69,0.2);
        border: 1px solid #dc3545;
        color: #ff6b6b;
        padding: 5px 15px;
        border-radius: 20px;
        cursor: pointer;
        transition: all 0.3s ease;
    }
    .btn-remove-question:hover {
        background: #dc3545;
        color: white;
    }
    .btn-save-questions {
        background: linear-gradient(135deg, var(--gold), var(--gold-dark));
        color: var(--black);
        border: none;
        padding: 14px 30px;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }
    .btn-save-questions:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(212,175,55,0.4);
    }
    .btn-back {
        background: transparent;
        border: 1px solid var(--gold);
        color: var(--gold);
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }
    .btn-back:hover {
        background: var(--gold);
        color: var(--black);
    }
    .image-upload-btn {
        background: rgba(212,175,55,0.2);
        border: 1px solid var(--gold);
        color: var(--gold);
        padding: 8px 15px;
        border-radius: 8px;
        cursor: pointer;
        display: inline-block;
        margin-top: 5px;
    }
    .image-upload-btn:hover {
        background: var(--gold);
        color: var(--black);
    }
    .toggle-icon {
        transition: transform 0.3s ease;
    }
    .toggle-icon.rotated {
        transform: rotate(180deg);
    }
</style>

<div class="container mt-4">
    <div class="questions-container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="gold-text"><i class="fas fa-tasks"></i> Add Questions</h2>
                <p class="text-white">Exam: <strong><%= exam.title %></strong></p>
                <p class="text-muted"><i class="fas fa-info-circle"></i> Click on question header to expand/collapse</p>
            </div>
            <div>
                <a href="/admin/exams" class="btn-back mr-2">
                    <i class="fas fa-list"></i> Manage Exams
                </a>
                <a href="/admin/dashboard" class="btn-back">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </div>

        <div id="questions-list"></div>

        <button type="button" class="btn-add-question" onclick="addQuestion()">
            <i class="fas fa-plus-circle"></i> Add New Question
        </button>

        <div class="text-center mt-4">
            <button class="btn-save-questions" onclick="saveAllQuestions()">
                <i class="fas fa-save"></i> Save All Questions
            </button>
        </div>
    </div>
</div>

<script>
    const examId = '<%= exam.id %>';
    let questionCount = 0;
    let questions = [];

    function previewImage(input, previewId) {
        const preview = document.getElementById(previewId);
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
                preview.classList.add('active');
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

    function toggleQuestion(questionId) {
        const body = document.getElementById(`question-body-${questionId}`);
        const icon = document.getElementById(`toggle-icon-${questionId}`);
        body.classList.toggle('active');
        icon.classList.toggle('rotated');
    }

    function addQuestion() {
        questionCount++;
        const questionHtml = `
            <div class="question-card" id="question-${questionCount}" data-id="${questionCount}">
                <div class="question-header" onclick="toggleQuestion(${questionCount})">
                    <span class="question-number">
                        <i class="fas fa-chevron-down toggle-icon" id="toggle-icon-${questionCount}"></i>
                        Question ${questionCount}
                    </span>
                    <button type="button" class="btn-remove-question" onclick="event.stopPropagation(); removeQuestion(${questionCount})">
                        <i class="fas fa-trash"></i> Remove
                    </button>
                </div>
                <div class="question-body" id="question-body-${questionCount}">
                    <!-- Question Text -->
                    <div class="form-group mb-3">
                        <label><i class="fas fa-question-circle"></i> Question Text</label>
                        <textarea class="form-control" id="q_text_${questionCount}" rows="3"
                                  placeholder="Enter your question here..."></textarea>
                    </div>

                    <!-- Question Image -->
                    <div class="form-group mb-3">
                        <label><i class="fas fa-image"></i> Question Image (Optional)</label>
                        <input type="file" class="image-input" id="q_image_file_${questionCount}"
                               accept="image/*" onchange="previewImage(this, 'q_image_preview_${questionCount}')">
                        <input type="hidden" id="q_image_${questionCount}" value="">
                        <img id="q_image_preview_${questionCount}" class="image-preview">
                    </div>

                    <div class="options-grid">
                        <!-- Option A -->
                        <div class="option-card">
                            <label>A.</label>
                            <input type="text" class="option-input" id="q_a_${questionCount}" placeholder="Option A text">
                            <input type="file" class="image-input" id="q_a_image_file_${questionCount}"
                                   accept="image/*" onchange="previewImage(this, 'q_a_preview_${questionCount}')">
                            <input type="hidden" id="q_a_image_${questionCount}" value="">
                            <img id="q_a_preview_${questionCount}" class="image-preview">
                        </div>

                        <!-- Option B -->
                        <div class="option-card">
                            <label>B.</label>
                            <input type="text" class="option-input" id="q_b_${questionCount}" placeholder="Option B text">
                            <input type="file" class="image-input" id="q_b_image_file_${questionCount}"
                                   accept="image/*" onchange="previewImage(this, 'q_b_preview_${questionCount}')">
                            <input type="hidden" id="q_b_image_${questionCount}" value="">
                            <img id="q_b_preview_${questionCount}" class="image-preview">
                        </div>

                        <!-- Option C -->
                        <div class="option-card">
                            <label>C.</label>
                            <input type="text" class="option-input" id="q_c_${questionCount}" placeholder="Option C text">
                            <input type="file" class="image-input" id="q_c_image_file_${questionCount}"
                                   accept="image/*" onchange="previewImage(this, 'q_c_preview_${questionCount}')">
                            <input type="hidden" id="q_c_image_${questionCount}" value="">
                            <img id="q_c_preview_${questionCount}" class="image-preview">
                        </div>

                        <!-- Option D -->
                        <div class="option-card">
                            <label>D.</label>
                            <input type="text" class="option-input" id="q_d_${questionCount}" placeholder="Option D text">
                            <input type="file" class="image-input" id="q_d_image_file_${questionCount}"
                                   accept="image/*" onchange="previewImage(this, 'q_d_preview_${questionCount}')">
                            <input type="hidden" id="q_d_image_${questionCount}" value="">
                            <img id="q_d_preview_${questionCount}" class="image-preview">
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <label><i class="fas fa-check-circle"></i> Correct Answer</label>
                            <select class="form-control" id="q_correct_${questionCount}">
                                <option value="A">A</option>
                                <option value="B">B</option>
                                <option value="C">C</option>
                                <option value="D">D</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label><i class="fas fa-trophy"></i> Marks</label>
                            <input type="number" class="form-control" id="q_marks_${questionCount}" value="1" min="1">
                        </div>
                    </div>
                </div>
            </div>
        `;

        document.getElementById('questions-list').insertAdjacentHTML('beforeend', questionHtml);
    }

    function removeQuestion(questionId) {
        if (confirm('Are you sure you want to remove this question?')) {
            const element = document.getElementById(`question-${questionId}`);
            if (element) {
                element.remove();
            }
        }
    }

    function saveAllQuestions() {
        const questions = [];
        const questionElements = document.querySelectorAll('.question-card');

        if (questionElements.length === 0) {
            alert('Please add at least one question!');
            return;
        }

        questionElements.forEach((element) => {
            const id = element.getAttribute('data-id');
            const questionText = document.getElementById(`q_text_${id}`)?.value || '';

            if (questionText.trim()) {
                questions.push({
                    text: questionText,
                    questionImage: document.getElementById(`q_image_${id}`)?.value || '',
                    optionA: document.getElementById(`q_a_${id}`)?.value || '',
                    optionB: document.getElementById(`q_b_${id}`)?.value || '',
                    optionC: document.getElementById(`q_c_${id}`)?.value || '',
                    optionD: document.getElementById(`q_d_${id}`)?.value || '',
                    optionAImage: document.getElementById(`q_a_image_${id}`)?.value || '',
                    optionBImage: document.getElementById(`q_b_image_${id}`)?.value || '',
                    optionCImage: document.getElementById(`q_c_image_${id}`)?.value || '',
                    optionDImage: document.getElementById(`q_d_image_${id}`)?.value || '',
                    correctAnswer: document.getElementById(`q_correct_${id}`)?.value || 'A',
                    marks: parseInt(document.getElementById(`q_marks_${id}`)?.value || 1)
                });
            }
        });

        if (questions.length === 0) {
            alert('Please add at least one valid question!');
            return;
        }

        // Save to server
        const saveBtn = document.querySelector('.btn-save-questions');
        const originalText = saveBtn.innerHTML;
        saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
        saveBtn.disabled = true;

        fetch('/admin/add-questions', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                examId: examId,
                questions: questions
            })
        })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert(`✅ Successfully saved ${questions.length} questions!`);
                    window.location.href = '/admin/exams';
                } else {
                    alert('Error: ' + (data.message || 'Unknown error'));
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error saving questions. Please try again.');
            })
            .finally(() => {
                saveBtn.innerHTML = originalText;
                saveBtn.disabled = false;
            });
    }

    // Add first question on load
    document.addEventListener('DOMContentLoaded', () => addQuestion());
</script>

<%- include('../partials/footer') %>